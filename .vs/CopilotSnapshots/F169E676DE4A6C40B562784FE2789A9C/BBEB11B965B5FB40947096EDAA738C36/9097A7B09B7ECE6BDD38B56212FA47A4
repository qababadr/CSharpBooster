<UserControl x:Class="CoreUI.Component.AppWindow.ConfirmDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoreUI.Component.AppWindow"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock
            Margin="10"
            VerticalAlignment="Center"
            Style="{StaticResource BodyMedium}"
            Foreground="{StaticResource Foreground}"
            Text="{Binding
            Text,
            RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <Separator 
            Margin="20"
            Foreground="{DynamicResource Secondary.Light}"/>

        <StackPanel
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Margin="0,0,20,0">
            <Button
                Background="{DynamicResource Secondary}"
                Click="OnCloseClick"
                Style="{StaticResource FlatButton}">
                <TextBlock
                    Foreground="{StaticResource Primary.Foreground}"
                    Style="{StaticResource BodyMedium}"
                    Text="{Binding
                    CancelLabel,
                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Button>
            <Button
                Margin="10,0,0,0"
                Style="{StaticResource ProgressFlatButton}"
                Click="OnConfirmClick"
                Background="{StaticResource Primary}"
                Command="{Binding 
                ConfirmCommand,
                RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding
                ConfirmCommandParameter,
                RelativeSource={RelativeSource AncestorType=UserControl}}">
                <TextBlock
                    Foreground="{StaticResource Primary.Foreground}"
                    Style="{StaticResource BodyMedium}"
                    Text="{Binding
                    ConfirmLabel,
                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
