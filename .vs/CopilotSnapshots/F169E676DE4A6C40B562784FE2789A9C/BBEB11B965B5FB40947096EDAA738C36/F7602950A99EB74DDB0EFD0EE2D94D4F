    public void ShowWithBackdropFilter(string id = "Dialog")
    {
        if (Owner == null && Application.Current?.MainWindow != null && this != Application.Current.MainWindow)
        {
            try { Owner = Application.Current.MainWindow; } catch { /* ignore */ }
        }
        WindowTracker.Register(id, this);
        ShowDialog();
    }

    private void OnCloseClick(object sender, MouseButtonEventArgs e)
    {
        Close();
    }

    private void OnMouseDown(object sender, System.Windows.Input.MouseButtonEventArgs e)
    {
        if (e.ChangedButton == MouseButton.Left)
            DragMove();
    }

    private void OnWindowMaximized(object sender, MouseButtonEventArgs e)
    {
        WindowState
            = WindowState == WindowState.Maximized ? WindowState.Normal : WindowState.Maximized;
    }
