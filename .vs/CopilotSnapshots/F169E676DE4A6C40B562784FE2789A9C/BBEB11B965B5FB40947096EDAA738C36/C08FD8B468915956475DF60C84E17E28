<UserControl x:Class="CoreUI.Component.BreadcrumbNavigation.Breadcrumb"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoreUI.Component" 
             xmlns:svgl="https://github.com/dotnetprojects/SVGImage"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:Images="clr-namespace:CoreUI.Assets.Images" 
             xmlns:Converter="clr-namespace:CoreUI.Component.BreadcrumbNavigation.Converter">

    <UserControl.Resources>
        <Converter:BreadcrumbLastItemConverter 
            x:Key="BreadcrumbLastItemConverter" />

        <Converter:BreadcrumbBeforeLastItemConverter 
            x:Key="BreadcrumbBeforeLastItemConverter" />
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal">

        <Border
            Name="PART_BackButton"
            Width="40"
            Height="40"
            Margin="14,0,12,6"
            Padding="6"
            CornerRadius="{StaticResource MDRadius}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource Background}"
            Cursor="Hand"
            Visibility="Collapsed"
            MouseDown="OnBackClick">
            <Border.Effect>
                <DropShadowEffect 
                    BlurRadius="10" 
                    ShadowDepth="5"
                    Direction="270"
                    Color="Black"
                    Opacity="0.4"/>
            </Border.Effect>
            <svgl:SVGImage
                Source="{x:Static Images:ImageResources.ArrowBack}"
                OverrideFillColor="{Binding
                Source={StaticResource Foreground},
                Path=Color}"/>
        </Border>

        <Image
            x:Name="PART_Logo"
            Width="50"
            Height="50"
            Stretch="UniformToFill"
            Margin="14,0,4,0"
            SnapsToDevicePixels="True"
            RenderOptions.BitmapScalingMode="HighQuality"
            Source="{Binding
            LogoSource,
            RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <ItemsControl ItemsSource="{Binding Items}">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Padding="1"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnBreadCrumbItemClick">

                            <Button.Style>
                                <Style 
                                    BasedOn="{StaticResource UnstyledButton}"
                                    TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding 
                                                    Converter="{StaticResource BreadcrumbLastItemConverter}">
                                                    <Binding Path="." />
                                                    <Binding 
                                                        Path="ItemsSource" 
                                                        RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter 
                                                Property="IsEnabled" 
                                                Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Value="False">
                                            <DataTrigger.Binding>
                                                <MultiBinding 
                                                    Converter="{StaticResource BreadcrumbLastItemConverter}">
                                                    <Binding Path="." />
                                                    <Binding 
                                                        Path="ItemsSource" 
                                                        RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Setter Property="Cursor" Value="Hand" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <TextBlock
                                FontWeight="DemiBold"
                                FontSize="{StaticResource XLargeFontSize}"
                                Text="{Binding}"
                                TextTrimming="CharacterEllipsis">

                                <TextBlock.Style>
                                    <Style 
                                        TargetType="TextBlock" 
                                        BasedOn="{StaticResource TitleMedium}">
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding 
                                                        Converter="{StaticResource BreadcrumbLastItemConverter}">
                                                        <Binding Path="." />
                                                        <Binding 
                                                            Path="ItemsSource" 
                                                            RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="TextDecorations" Value="None" />
                                                <Setter Property="Foreground" Value="{DynamicResource Secondary}" />
                                            </DataTrigger>

                                            <DataTrigger Value="False">
                                                <DataTrigger.Binding>
                                                    <MultiBinding 
                                                        Converter="{StaticResource BreadcrumbLastItemConverter}">
                                                        <Binding Path="." />
                                                        <Binding 
                                                            Path="ItemsSource" 
                                                            RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="TextDecorations" Value="Underline" />
                                                <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <TextBlock
                            FontSize="{StaticResource XLargeFontSize}"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Foreground="{StaticResource Foreground}"
                            Text=" / ">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TitleMedium}">
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding 
                                                    Converter="{StaticResource BreadcrumbLastItemConverter}">
                                                    <Binding Path="." />
                                                    <Binding 
                                                        Path="ItemsSource" 
                                                        RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>