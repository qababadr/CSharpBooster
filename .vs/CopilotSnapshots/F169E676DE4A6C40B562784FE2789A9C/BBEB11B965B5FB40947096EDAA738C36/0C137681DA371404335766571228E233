<UserControl x:Class="CoreUI.Component.WarningMessage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoreUI.Component"
             xmlns:svgl="https://github.com/dotnetprojects/SVGImage"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border
        Name="Root"
        Background="{Binding
        Background,
        RelativeSource={RelativeSource AncestorType=UserControl}}"
        BorderThickness="1"
        CornerRadius="{StaticResource MDBorderRadius}"
        RenderTransformOrigin="0.5,1">

        <Border.RenderTransform>
            <ScaleTransform
                x:Name="AnimatedScaleTransform"
                ScaleY="0" />
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="8"
                Opacity="0.5"
                ShadowDepth="2"
                Color="Black"/>
        </Border.Effect>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width=".95*" />
            </Grid.ColumnDefinitions>

            <svgl:SVGImage
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                Width="20"
                Height="20"
                OverrideFillColor="{Binding 
                Source={StaticResource Primary.Foreground}, 
                Path=Color}"
                Source="{Binding 
                IconName,
                RelativeSource={RelativeSource AncestorType=UserControl}}" />

            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                AutomationProperties.AutomationId="{Binding 
                AID,
                RelativeSource={RelativeSource AncestorType=UserControl}}"
                Foreground="{StaticResource Primary.Foreground}"
                Style="{StaticResource BodyLarge}"
                Text="{Binding 
                Text,
                RelativeSource={RelativeSource AncestorType=UserControl}}"
                TextAlignment="Left"
                TextWrapping="Wrap" />

        </Grid>

    </Border>
</UserControl>
