    public event EventHandler<bool>? HasFocusChanged;
    public event EventHandler<object>? SuggestedItemSelected;

    private readonly SolidColorBrush? _labelBackgroundBrush;

    public TextField()
    {
        InitializeComponent();

        _labelBackgroundBrush = new SolidColorBrush(Colors.Transparent);

        TextLabel.Background = _labelBackgroundBrush;

        AttachFocusEvent();

        AttachLostFocusEvent();

        if (Type == TextFieldType.AutoComplete)
        {
            AttachUpdateDropdown();
        }

        Loaded += (_, _) =>
        {
            switch (Type)
            {
                case TextFieldType.Noraml:
                    UseNormalTextBox();
                    break;

                case TextFieldType.AutoComplete:
                    UseAutoComplete();
                    break;

                case TextFieldType.Password:
                    UsePasswordBox();
                    break;
            }
        };
    }

    private void AttachLostFocusEvent()
    {
        switch (Type)
        {
            case TextFieldType.Noraml:
                AttachLostFocusForTextBox();
                break;

            case TextFieldType.AutoComplete:
                AttachLostFocusForAutoComplete();
                break;

            case TextFieldType.Password:
                AttachLostFocusForPasswordBox();
                break;
        }
    }

    private void AttachFocusEvent()
    {
        switch (Type)
        {
            case TextFieldType.Noraml:
                AttachFocusEventForTextBox();
                break;

            case TextFieldType.AutoComplete:
                AttachFocusEventForAutoComplete();
                break;

            case TextFieldType.Password:
                AttachFocusEventForPasswordBox();
                break;
        }
    }

    private static void OnTypePropertyChange(DependencyObject d, DependencyPropertyChangedEventArgs e)
    {
        if (d is TextField textField)
        {
            switch (textField.Type)
            {
                case TextFieldType.Noraml:
                    textField.AttachFocusEventForTextBox();
                    textField.AttachLostFocusForTextBox();
                    textField.UseNormalTextBox();
                    break;
                case TextFieldType.AutoComplete:
                    textField.AttachFocusEventForAutoComplete();
                    textField.AttachLostFocusForAutoComplete();
                    textField.AttachUpdateDropdown();
                    textField.UseAutoComplete();
                    break;
                case TextFieldType.Password:
                    textField.AttachFocusEventForPasswordBox();
                    textField.AttachLostFocusForPasswordBox();
                    textField.UsePasswordBox();
                    break;
            }
        }
    }

    private void UseAutoComplete()
    {
        PART_NormalTextBox.Visibility = Visibility.Collapsed;
        PART_PasswordBox.Visibility = Visibility.Collapsed;
        PART_AutoCompleteTextBox.Visibility = Visibility.Visible;
    }

    private void AttachUpdateDropdown()
    {
        PART_AutoCompleteTextBox.AddHandler(
            TextBoxBase.TextChangedEvent,
            new TextChangedEventHandler((s, e) =>
            {
                UpdateDropdown();
            })
        );
    }

    private void UpdateDropdown()
    {
        bool hasSuggestions = Suggestions != null && Suggestions.Any();
        bool hasText = !string.IsNullOrWhiteSpace(PART_AutoCompleteTextBox.Text);

        PART_AutoCompleteTextBox.IsDropDownOpen = hasSuggestions && hasText;
    }

    private void AttachLostFocusForAutoComplete()
    {
        PART_AutoCompleteTextBox.LostFocus += (_, _) =>
        {
            HasFocus = false;
            HasFocusChanged?.Invoke(this, false);
            if (string.IsNullOrWhiteSpace(PART_AutoCompleteTextBox.Text))
            {
                AnimateLabelDown();
            }

            PART_AutoCompleteTextBox.IsDropDownOpen = false;
        };
    }

    private void AttachFocusEventForAutoComplete()
    {
        TextLabel.Target = PART_AutoCompleteTextBox;
        PART_AutoCompleteTextBox.GotFocus += (s, e) =>
        {
            HasFocus = true;
            HasFocusChanged?.Invoke(this, true);

            AnimateLabelUp();

            UpdateDropdown();
        };
    }

    private void UsePasswordBox()
    {
        PART_NormalTextBox.Visibility = Visibility.Collapsed;
        PART_PasswordBox.Visibility = Visibility.Visible;
        PART_AutoCompleteTextBox.Visibility = Visibility.Collapsed;
    }

    private void AttachLostFocusForPasswordBox()
    {
        TextLabel.Target = PART_PasswordBox;
        PART_PasswordBox.GotFocus += (s, e) =>
        {
            HasFocus = true;
            HasFocusChanged?.Invoke(this, true);

            AnimateLabelUp();
        };
    }

    private void AttachFocusEventForPasswordBox()
    {
        PART_PasswordBox.LostFocus += (_, _) =>
        {
            HasFocus = false;
            HasFocusChanged?.Invoke(this, false);

            if (string.IsNullOrWhiteSpace(PART_PasswordBox.Password))
            {
                AnimateLabelDown();
            }
        };
    }

    private void UseNormalTextBox()
    {
        PART_NormalTextBox.Visibility = Visibility.Visible;
        PART_PasswordBox.Visibility = Visibility.Collapsed;
        PART_AutoCompleteTextBox.Visibility = Visibility.Collapsed;
    }

    private void AttachLostFocusForTextBox()
    {
        PART_NormalTextBox.LostFocus += (_, _) =>
        {
            HasFocus = false;
            HasFocusChanged?.Invoke(this, false);
            if (string.IsNullOrWhiteSpace(PART_NormalTextBox.Text))
            {
                AnimateLabelDown();
            }
        };
    }

    private void AttachFocusEventForTextBox()
    {
        TextLabel.Target = PART_NormalTextBox;
        PART_NormalTextBox.GotFocus += (s, e) =>
        {
            HasFocus = true;
            HasFocusChanged?.Invoke(this, true);

            AnimateLabelUp();
        };
    }

    private void AnimateLabelUp()
    {
        var duration = TimeSpan.FromMilliseconds(200);

        var yAnimation = new DoubleAnimation
        {
            To = -24,
            Duration = duration,
            EasingFunction = new QuadraticEase { EasingMode = EasingMode.EaseOut },
        };

        var xAnimation = new DoubleAnimation
        {
            To = -4,
            Duration = duration,
            EasingFunction = new QuadraticEase { EasingMode = EasingMode.EaseOut },
        };

        LabelTransform?.BeginAnimation(TranslateTransform.YProperty, yAnimation);
        LabelTransform?.BeginAnimation(TranslateTransform.XProperty, xAnimation);

        AnimateLabelBackgroundColor(
            Colors.Transparent,
            TargetLabelBackgroundColor()
        );
    }

    private void AnimateLabelBackgroundColor(Color fromColor, Color toColor)
    {
        if (_labelBackgroundBrush == null)
            return;

        _labelBackgroundBrush.Color = fromColor;

        var colorAnimation = new ColorAnimation
        {
            From = fromColor,
            To = toColor,
            Duration = TimeSpan.FromMilliseconds(200),
            EasingFunction = new QuadraticEase { EasingMode = EasingMode.EaseOut },
        };

        _labelBackgroundBrush.BeginAnimation(SolidColorBrush.ColorProperty, colorAnimation);
    }

    private void AnimateLabelDown()
    {
        var duration = TimeSpan.FromMilliseconds(200);

        var yAnimation = new DoubleAnimation
        {
            To = 0,
            Duration = duration,
            EasingFunction = new QuadraticEase { EasingMode = EasingMode.EaseOut },
        };

        var xAnimation = new DoubleAnimation
        {
            To = 4,
            Duration = duration,
            EasingFunction = new QuadraticEase { EasingMode = EasingMode.EaseOut },
        };

        LabelTransform?.BeginAnimation(TranslateTransform.YProperty, yAnimation);
        LabelTransform?.BeginAnimation(TranslateTransform.XProperty, xAnimation);

        AnimateLabelBackgroundColor(
            ThemeSwitcher.GetThemeBackgroundColor(),
            Colors.Transparent
        );
    }

    private void OnSelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (sender is ComboBox comboBox && comboBox.SelectedItem is object selectedItem)
        {
            SuggestedItemSelected?.Invoke(this, selectedItem);
        }
    }

    private Color TargetLabelBackgroundColor()
    {
        if (UsingSurfaceAsLabelBackground)
            return ThemeSwitcher.GetThemeSurfaceColor();

        return ThemeSwitcher.GetThemeBackgroundColor();
    }
