using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;

namespace CoreUI.Component.AppWindow;

public partial class ConfirmDialogContent : UserControl
{
    /* =======================
         *  Text
         * ======================= */
    public static readonly DependencyProperty TextProperty =
        DependencyProperty.Register(
            nameof(Text),
            typeof(string),
            typeof(ConfirmDialogContent),
            new PropertyMetadata(string.Empty));

    public string Text
    {
        get => (string)GetValue(TextProperty);
        set => SetValue(TextProperty, value);
    }

    /* =======================
     *  CancelLabel
     * ======================= */
    public static readonly DependencyProperty CancelLabelProperty =
        DependencyProperty.Register(
            nameof(CancelLabel),
            typeof(string),
            typeof(ConfirmDialogContent),
            new PropertyMetadata("Cancel"));

    public string CancelLabel
    {
        get => (string)GetValue(CancelLabelProperty);
        set => SetValue(CancelLabelProperty, value);
    }

    /* =======================
     *  ConfirmLabel
     * ======================= */
    public static readonly DependencyProperty ConfirmLabelProperty =
        DependencyProperty.Register(
            nameof(ConfirmLabel),
            typeof(string),
            typeof(ConfirmDialogContent),
            new PropertyMetadata("Confirm"));

    public string ConfirmLabel
    {
        get => (string)GetValue(ConfirmLabelProperty);
        set => SetValue(ConfirmLabelProperty, value);
    }

    /* =======================
     *  ConfirmCommand
     * ======================= */
    public static readonly DependencyProperty ConfirmCommandProperty =
        DependencyProperty.Register(
            nameof(ConfirmCommand),
            typeof(ICommand),
            typeof(ConfirmDialogContent));

    public ICommand? ConfirmCommand
    {
        get => (ICommand?)GetValue(ConfirmCommandProperty);
        set => SetValue(ConfirmCommandProperty, value);
    }

    /* =======================
     *  ConfirmCommandParameter
     * ======================= */
    public static readonly DependencyProperty ConfirmCommandParameterProperty =
        DependencyProperty.Register(
            nameof(ConfirmCommandParameter),
            typeof(object),
            typeof(ConfirmDialogContent));

    public object? ConfirmCommandParameter
    {
        get => GetValue(ConfirmCommandParameterProperty);
        set => SetValue(ConfirmCommandParameterProperty, value);
    }

    public event EventHandler? CancelClick;
    public event EventHandler? ConfirmClick;

    public ConfirmDialogContent()
    {
        InitializeComponent();
    }

    private void OnCloseClick(object sender, RoutedEventArgs e)
        => CancelClick?.Invoke(this, e);

    private void OnConfirmClick(object sender, RoutedEventArgs e)
        => ConfirmClick?.Invoke(this, e);
}
